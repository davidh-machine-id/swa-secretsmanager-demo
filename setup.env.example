# ============================================================
# SWA + SECRETS MANAGER DEMO - ENVIRONMENT CONFIGURATION
# ============================================================
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp setup.env.example setup.env
# 2. Edit setup.env with your actual values
# ============================================================

# ============================================================
# PROJECT PREFIX (Required)
# ============================================================

# Prefix used to compute names of resources
PROJECT_PREFIX="my-demo"

# ============================================================
# Secrets Manager (aka Conjur)
# ============================================================
# Conjur tenant subdomain (e.g., "my-tenant" for my-tenant.secretsmgr.cyberark.cloud)
CONJUR_TENANT="my-tenant"

# Credentials for Conjur CLI login
# TODO: add required conjur account permissions in comments
CONJUR_USER='your-user@cyberark.cloud.xxxxx'
CONJUR_PASS='your-password-here'

CONJUR_APPLIANCE_URL="https://${CONJUR_TENANT}.secretsmgr.cyberark.cloud/api"

# ============================================================
# App settings
# ============================================================
APP_NAME="demo-app"
APP_NAMESPACE="$APP_NAME"
APP_SERVICE_ACCT="$APP_NAME-sa"
APP_IMAGE_REPOSITORY="docker.io/library/$APP_NAME"
APP_IMAGE_TAG="latest"
APP_DIR="./app"

APP_SECRET_PATH="data/${PROJECT_PREFIX}/secrets/${PROJECT_PREFIX}-app/api-key"
APP_SECRET_VALUE="YourSecretValueHere"  # Initial secret value to set

# ============================================================
# KIND CLUSTER
# ============================================================

KIND_CLUSTER_NAME="${PROJECT_PREFIX}"

# ============================================================
# SWA CONFIGURATION
# ============================================================

# SPIFFE trust domain configured in your SWA control plane
SWA_TRUST_DOMAIN="${PROJECT_PREFIX}.workload-az.com"

# Do not add "/api" suffix
SWA_CONJUR_APPLIANCE_URL="https://${CONJUR_TENANT}.secretsmgr.cyberark.cloud"

SWA_CLUSTER_NAME="${PROJECT_PREFIX}"
SWA_AGENT_SOCKET_PATH="/tmp/swa-agent/public/api.sock"
SWA_NODEGROUP="k8s-nodegroup"
SWA_SERVER_GROUP_NAME="${PROJECT_PREFIX}-k8s"
SWA_SERVER_NAME="${PROJECT_PREFIX}-k8s-swa-server"

# TF provider version is set from ./scripts/swa-release-prep.sh
SWA_TERRAFORM_PROVIDER_VERSION="0.1.0-c2081762-821"

# When using Kind, we load images directly into kind, so reference the local image
SWA_IMAGE_REGISTRY="docker.io/library"

# These are populated by ./scripts/kind-load-swa-images.sh
SWA_SERVER_IMAGE="swa-server"
SWA_SERVER_IMAGE_TAG=""
SWA_AGENT_IMAGE="swa-agent"
SWA_AGENT_IMAGE_TAG=""

# SWA Kubernetes namespace
SWA_NAMESPACE="swa-system"

SWA_CONTROL_PLANE_LOGIN_URL="${CONJUR_APPLIANCE_URL}/authn-jwt/${PROJECT_PREFIX}"
SWA_NODEGROUP_NAME="$SWA_NODEGROUP"
SPIFFE_ID="spiffe://$SWA_TRUST_DOMAIN/$SWA_NODEGROUP/ns/$APP_NAMESPACE/sa/$APP_SERVICE_ACCT"
